<Window
    x:Class="SampleProject.Popup.MyPopupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SampleProject.Popup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MyPopupWindow"
    Width="400"
    Height="450"
    d:DataContext="{d:DesignInstance Type=local:MyPopup}"
    Background="#202020"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

        <TextBlock
            FontSize="24"
            Foreground="White"
            Text="Some popup data" />

        <Button
            Margin="0,16,0,0"
            Padding="16,8"
            Command="{Binding CloseCommand}"
            Content="Close (intentionally)"
            FontSize="16" />

    </StackPanel>

</Window>
