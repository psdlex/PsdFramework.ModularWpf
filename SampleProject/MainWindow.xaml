<Window
    x:Class="SampleProject.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SampleProject"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:navigatables="clr-namespace:SampleProject.Navigatables"
    Title="MainWindow"
    Width="1024"
    Height="576"
    d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel}"
    Background="#101010"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <DataTemplate DataType="{x:Type navigatables:SingletonNavigatable}">
            <Border
                BorderBrush="Blue"
                BorderThickness="2">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <TextBlock
                        FontSize="32"
                        Foreground="White"
                        Text="This is a singleton page! Unique Id:" />
                    <TextBlock
                        FontSize="24"
                        Foreground="Gray"
                        Text="{Binding Id}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type navigatables:TransientNavigatable}">
            <Border
                BorderBrush="Orange"
                BorderThickness="2">
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <TextBlock
                        FontSize="32"
                        Foreground="White"
                        Text="This is a transient page! Unique Id:" />
                    <TextBlock
                        FontSize="24"
                        Foreground="Gray"
                        Text="{Binding Id}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="32">

        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ContentControl Content="{Binding CurrentModel}" />

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">

            <Button
                Padding="16,8"
                Command="{Binding NavigateToSingletonNavigatableCommand}"
                Content="Navigate to singleton page" />

            <Button
                Margin="16,0,0,0"
                Padding="16,8"
                Command="{Binding NavigateToTransientNavigatableCommand}"
                Content="Navigate to transient page" />

            <Button
                Margin="16,0,0,0"
                Padding="16,8"
                Command="{Binding ShowPopupCommand}"
                Content="Show popup" />



        </StackPanel>

    </Grid>
</Window>
